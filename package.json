{
  "name": "claude-setting-manager",
  "displayName": "Claude Setting Manager",
  "description": "A VS Code extension to manage multiple Claude Code API profiles and switch between them without manually editing settings.json.",
  "version": "1.0.0",
  "publisher": "jiang1997",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:claudeProfiles"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeSettingManager.addProfile",
        "title": "Claude Setting: Add Profile",
        "category": "Claude Setting"
      },
      {
        "command": "claudeSettingManager.switchProfile",
        "title": "Claude Setting: Switch Profile",
        "category": "Claude Setting"
      },
      {
        "command": "claudeSettingManager.editProfile",
        "title": "Edit",
        "category": "Claude Setting"
      },
      {
        "command": "claudeSettingManager.deleteProfile",
        "title": "Delete",
        "category": "Claude Setting"
      },
      {
        "command": "claudeSettingManager.activateProfile",
        "title": "Activate Profile",
        "category": "Claude Setting"
      }
    ],
    "configuration": [
      {
        "type": "object",
        "title": "Claude Setting Manager",
        "properties": {
          "claudeSettingManager.environmentVariableName": {
            "type": "string",
            "default": "ANTHROPIC_BASE_URL",
            "description": "Environment variable name for the API base URL inserted into the 'claudeCode.environmentVariables' setting."
          }
        }
      },
      {
        "type": "object",
        "title": "Claude Code",
        "properties": {
          "claudeCode.environmentVariables": {
            "type": "array",
            "default": [],
            "description": "Environment variables passed to Claude Code.",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeProfiles",
          "title": "Claude Profiles",
          "icon": "$(account)"
        }
      ]
    },
    "views": {
      "claudeProfiles": [
        {
          "id": "claudeProfiles",
          "name": "Profiles"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "claudeSettingManager.editProfile",
          "when": "view == claudeProfiles && viewItem == claudeProfile",
          "group": "inline"
        },
        {
          "command": "claudeSettingManager.deleteProfile",
          "when": "view == claudeProfiles && viewItem == claudeProfile"
        }
      ],
      "view/title": [
        {
          "command": "claudeSettingManager.addProfile",
          "when": "view == claudeProfiles",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "test": "npm run compile && mocha out/test/**/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  }
}
