{
  "name": "claude-profile-manager",
  "displayName": "Claude Profile Manager",
  "description": "A VS Code extension to manage multiple Claude Code API profiles and switch between them without manually editing settings.json.",
  "version": "1.0.0",
  "publisher": "jiang1997",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:claudeSettingManager.manageProfiles"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeSettingManager.manageProfiles",
        "title": "Manage Profiles",
        "category": "Claude Setting"
      }
    ],
    "configuration": [
      {
        "type": "object",
        "title": "Claude Setting Manager",
        "properties": {
          "claudeSettingManager.environmentVariableName": {
            "type": "string",
            "default": "ANTHROPIC_BASE_URL",
            "description": "Environment variable name for the API base URL inserted into the 'claudeCode.environmentVariables' setting."
          }
        }
      },
      {
        "type": "object",
        "title": "Claude Code",
        "properties": {
          "claudeCode.environmentVariables": {
            "type": "array",
            "default": [],
            "description": "Environment variables passed to Claude Code.",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "test": "npm run compile && mocha out/test/**/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  }
}
